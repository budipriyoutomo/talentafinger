# =========================================================================
# ENV untuk deployment Docker (salin ke .env.docker, JANGAN commit yang asli).
# Dipakai service app/queue/scheduler via env_file. Host diarahkan ke nama
# service compose (db, redis). Laravel: env nyata menang atas file .env.
# =========================================================================

APP_NAME="ADMS Middleware"
APP_ENV=production
# Generate sekali: docker compose run --rm app php artisan key:generate --show
APP_KEY=
APP_DEBUG=false
# HTTPS diterminasi Cloudflare (proxied). Pakai domain + https di sini supaya
# URL absolut, redirect, dan asset memakai https (origin tetap HTTP di balik CF).
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# stderr: log Laravel tampil di `docker compose logs` (konvensi container).
# Ganti ke stack/single bila ingin file di storage/logs.
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

# --- Database (PostgreSQL DI LUAR VPS) ---
# Arahkan ke host DB eksternal. Pastikan VPS bisa menjangkau host:port ini dan
# user DB mengizinkan koneksi dari IP VPS (pg_hba / firewall penyedia DB).
# Jika DB butuh SSL, tambahkan DB_SSLMODE=require.
DB_CONNECTION=pgsql
DB_HOST=db.eksternal.example.com
DB_PORT=5432
DB_DATABASE=adms_middleware
DB_USERNAME=adms
DB_PASSWORD=
# DB_SSLMODE=require

# --- Session / cache / queue (semua driver DATABASE, tanpa Redis) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Cookie hanya dikirim lewat HTTPS (aman karena visitor selalu via Cloudflare).
SESSION_SECURE_COOKIE=true
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# --- Mekari Talenta API ---
MEKARI_BASE_URL=https://api.mekari.com/v2/talenta/v2
MEKARI_CLIENT_ID=
MEKARI_CLIENT_SECRET=
MEKARI_FINGERPRINT_TOKEN=
MEKARI_FINGERPRINT_USER_ID=
MEKARI_RATE_LIMIT=60

# --- ADMS / mesin ZKTeco ---
ADMS_DEVICE_TIMEZONE=Asia/Jakarta
ADMS_PYTHON_BIN=python3
ADMS_SDK_PORT=4370

# --- Admin awal (AdminUserSeeder; set RUN_SEED=true di compose untuk seed) ---
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@adms.local
ADMIN_PASSWORD=password

# =========================================================================
# VPN L2TP/IPSec — dibaca compose (interpolasi ${...}) untuk service 'vpn'.
# Selalu jalankan compose dengan: --env-file .env.docker (lihat README_DOCKER.md)
# =========================================================================
VPN_SERVER=202.138.226.231
VPN_PSK=
VPN_USERNAME=
VPN_PASSWORD=
VPN_ROUTES=200.100.100.0/24

# Port origin HTTP yang dipublish container vpn; Cloudflare (proxied) menyambung
# ke VPS_IP:WEB_PORT. Port HTTP yang didukung Cloudflare proxied: 80, 8080, 8880,
# 2052, 2082, 2086, 2095. Default 80. Batasi port ini ke IP Cloudflare di firewall.
WEB_PORT=80
